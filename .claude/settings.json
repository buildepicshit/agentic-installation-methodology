{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Fleet baseline shared settings. Hooks use the `if` field with permission-rule syntax so triggers match Claude Code's actual command parser instead of regex on raw text. Per-repo permissions belong in .claude/settings.local.json (gitignored). Hook commands MUST use ${CLAUDE_PROJECT_DIR} so they resolve from the project root regardless of subprocess cwd drift.",
  "autoMemoryEnabled": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git add .)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-git-add-all.sh"
          },
          {
            "type": "command",
            "if": "Bash(git add -A *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-git-add-all.sh"
          },
          {
            "type": "command",
            "if": "Bash(git add --all *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-git-add-all.sh"
          },
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-push-to-main.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-ai-attribution.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-verify-bypass.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-probe-residue.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/block-stale-derived-artifacts.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-bad-cli-invocation.sh"
          },
          {
            "type": "command",
            "if": "Bash(copilot *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-bad-cli-invocation.sh"
          },
          {
            "type": "command",
            "if": "Bash(gh copilot *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-bad-cli-invocation.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(yarn *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pip *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pip3 *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(uv *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(poetry *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(go *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(cargo *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-security-surface.sh"
          },
          {
            "type": "command",
            "if": "Bash(git merge *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-verify-bypass.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-edit-on-main.sh"
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-subagent-routing.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/verify-reminder.sh"
          }
        ]
      }
    ]
  }
}
