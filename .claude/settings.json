{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Fleet baseline shared settings. MOST Bash hooks use the `if` field with permission-rule syntax so triggers match Claude Code's command parser instead of regex on raw text. ONE self-classifying hook (block-bad-cli-invocation) plus the advisory warn-security-surface are intentionally wired UN-GATED on the Bash matcher (no `if`): they fail-open cheaply and MUST see wrapped forms a name-prefixed matcher would miss (timeout/env/VAR=val prefixes) — prefilter breadth >= classifier breadth (SE-2, 2026-07-01-hook-guardrail-hardening). block-undeclared-deps stays GATED on package-manager prefixes (un-gating it false-positived on manifest strings in quoted args — 2026-07-10 cross-family review). Per-repo permissions belong in .claude/settings.local.json (gitignored). Hook commands MUST use ${CLAUDE_PROJECT_DIR} so they resolve from the project root regardless of subprocess cwd drift.",
  "autoMemoryEnabled": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/scripts/statusline.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-git-add-all.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-push-to-main.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-ai-attribution.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-verify-bypass.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-probe-residue.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-fleet-commit-sweep.sh"
          },
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/block-stale-derived-artifacts.sh"
          },
          {
            "type": "command",
            "$comment": "Un-gated on Bash: the hook self-classifies (greps the command for claude/copilot and fail-opens otherwise) and MUST see wrapped invocations too — timeout/env/VAR=val prefixes never start with the CLI name, so a name-prefixed matcher would miss them. Prefilter breadth >= classifier breadth (SE-2, 2026-07-01-hook-guardrail-hardening).",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-bad-cli-invocation.sh"
          },
          {
            "type": "command",
            "$comment": "GATED on package-manager prefixes (deliberately NOT un-gated). Un-gating this hook made it scrutinize every Bash command and false-positive on manifest-write strings inside quoted args / mentions (cross-family review, 2026-07-10). The manual-manifest-write-via-Bash class (sed -i package.json, echo >> requirements.txt, tee go.mod) stays a DOCUMENTED RESIDUAL; the Edit|Write matcher below covers the normal manifest-editing path, and any install command is caught here.",
            "if": "Bash(npm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(yarn *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pip *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(pip3 *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(uv *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(poetry *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(go *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "if": "Bash(cargo *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-security-surface.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-edit-on-main.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-undeclared-deps.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-security-surface.sh"
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/warn-subagent-routing.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/verify-reminder.sh"
          }
        ]
      }
    ]
  }
}
