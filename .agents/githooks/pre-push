#!/usr/bin/env bash
# BES fleet CI pre-push hook (managed by install-pre-push-hook.sh)
# Per specs/2026-05-25-fleet-ci-bootstrap/SPEC.md §7.4.
#
# The first-line comment IS the marker — install-pre-push-hook.sh
# uses it to detect "installed by us" vs a pre-existing user hook.
# DO NOT change that comment text without updating the installer.

set -uo pipefail

# Chain git-lfs FIRST: `git lfs pre-push` consumes the ref list on
# stdin (the CI-gate section below does not read stdin), and because
# the fleet sets core.hooksPath=.githooks, LFS's own hook under
# .git/hooks never fires — without this chain LFS objects are never
# uploaded and GitHub hard-rejects the first asset push (GH008).
# No-op where git-lfs is absent or no refs are LFS-tracked. Gated on
# $# so a MANUAL no-arg invocation still reaches the CI gates —
# no-arg `git lfs pre-push` aborts with exit 1 (r1 cross-family
# catch); git itself always passes <remote> <url>.
# Per specs/2026-07-01-pre-push-lfs-chaining/SPEC.md.
if [ "$#" -gt 0 ] && command -v git-lfs >/dev/null 2>&1; then
    git lfs pre-push "$@" || exit $?
fi

# Fleet-aware resolution: try .agents/ (propagated layout) then
# agents/ (source-repo layout).
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
runner=""
for candidate in \
    "$repo_root/.agents/scripts/run-ci-gates.sh" \
    "$repo_root/agents/scripts/run-ci-gates.sh"
do
    if [ -x "$candidate" ]; then
        runner="$candidate"
        break
    fi
done

# F-117: fail CLOSED. A missing runner means broken .agents/ propagation, not "no gates" —
# refuse the push rather than silently letting an ungated commit through.
if [ -z "$runner" ]; then
    echo "BES pre-push: run-ci-gates.sh not found — refusing to push (fail-closed, F-117)" >&2
    exit 1
fi

CLAUDE_PROJECT_DIR="$repo_root" bash "$runner" || exit $?

# F-36: also run the repo-local verification gate when the repo ships one. The fleet CI manifest
# (gates.txt) is cross-repo-shared and cannot carry a repo-specific gate — e.g. ACTOCCATUD's Rust
# fmt/clippy/determinism/nextest/deny gate — so the repo-local gate rides the hook here.
# Fail-closed: a present-but-failing gate blocks the push. Repos without one skip this (no-op).
local_gate="$repo_root/.githooks/verify-local.sh"
if [ -x "$local_gate" ]; then
    echo "BES pre-push: running repo-local gate ($local_gate)" >&2
    bash "$local_gate" || exit $?
fi
exit 0
